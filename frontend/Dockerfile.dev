# ---------- Development Dockerfile ----------
# Run with source code mounted as a volume for hot-reload:
#   docker compose -f docker-compose.dev.yml up
#
# Uses the pre-built ideaforge-preview-node base image which already contains
# Node + npm and the project's frontend dependencies pre-installed under
# /app/node_modules. IdeaForge's runner builds this base image automatically
# the first time it's needed (see apps/server/src/services/runner/base-images.ts).
FROM ideaforge-preview-node:latest
WORKDIR /app

# Source code will be mounted as a volume — not copied
EXPOSE 5173

CMD ["npm", "run", "dev"]
