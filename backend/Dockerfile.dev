# ---------- Development Dockerfile ----------
# Run with source code mounted as a volume for hot-reload:
#   docker compose -f docker-compose.dev.yml up
#
# Uses the pre-built ideaforge-preview-java base image which already contains
# JDK 21, Maven, and the project's Maven dependencies pre-downloaded.
# IdeaForge's runner builds this base image automatically the first time it's
# needed (see apps/server/src/services/runner/base-images.ts).
FROM ideaforge-preview-java:latest
WORKDIR /app

# Source code will be mounted as a volume — not copied
EXPOSE 8080

# spring-boot:run enables DevTools hot-restart automatically
CMD ["mvn", "spring-boot:run"]
